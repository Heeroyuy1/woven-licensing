# Woven Model Universal Licensing Platform
# Environment Configuration

# Application
APP_NAME="Woven Model Licensing Server"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-key
ENVIRONMENT=production

# Database
DATABASE_URL=postgresql+asyncpg://woven:woven_password@postgres:5432/woven_licensing
# For development SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./woven_licensing.db

# JWT
JWT_SECRET_KEY=change-this-jwt-secret-key
JWT_ALGORITHM=ES256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Signing Keys (Ed25519)
# Generate with: python -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey; key = Ed25519PrivateKey.generate(); print('PRIVATE:', key.private_bytes_raw().hex()); print('PUBLIC:', key.public_key().public_bytes_raw().hex())"
SIGNING_PRIVATE_KEY=
SIGNING_PUBLIC_KEY=

# SMTP / Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@wovenmodel.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# CORS
CORS_ORIGINS=http://localhost:3000,https://admin.wovenmodel.com,https://portal.wovenmodel.com

# Database Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Redis (optional, for caching)
REDIS_URL=
